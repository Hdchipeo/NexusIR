# =============================================================================
# Device Configuration — Per-device ESP-NOW mode + hardware config
# =============================================================================
menu "Device Configuration"

    menu "AC (Air Conditioner)"
        choice APP_ESPNOW_AC_MODE
            prompt "AC ESP-NOW Mode"
            default APP_ESPNOW_AC_DISABLED
            help
                Master: Send AC commands to slave nodes (no local IR needed).
                Slave:  Receive AC commands from master and send IR locally.
                Standalone: AC works locally, no ESP-NOW sync.
                Disabled: Hide from HomeKit, do not initialize.

            config APP_ESPNOW_AC_MASTER
                bool "Master"
            config APP_ESPNOW_AC_SLAVE
                bool "Slave"
            config APP_ESPNOW_AC_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_AC_DISABLED
                bool "Disabled"
        endchoice

        config APP_ESPNOW_AC_MAC
            string "AC Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_AC_MASTER
            help
                The MAC address of the slave device to send AC commands to.
                Format: XX:XX:XX:XX:XX:XX
    endmenu

    menu "Fan"
        choice APP_ESPNOW_FAN_MODE
            prompt "Fan ESP-NOW Mode"
            default APP_ESPNOW_FAN_DISABLED
            help
                Master: Send Fan commands to slave nodes (no local IR needed).
                Slave:  Receive Fan commands from master and send IR locally.
                Standalone: Fan works locally, no ESP-NOW sync.
                Disabled: Hide from HomeKit, do not initialize.

            config APP_ESPNOW_FAN_MASTER
                bool "Master"
            config APP_ESPNOW_FAN_SLAVE
                bool "Slave"
            config APP_ESPNOW_FAN_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_FAN_DISABLED
                bool "Disabled"
        endchoice

        config APP_ESPNOW_FAN_MAC
            string "Fan Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_FAN_MASTER
            help
                The MAC address of the slave device to send Fan commands to.
                Format: XX:XX:XX:XX:XX:XX
    endmenu

    menu "Temperature & Humidity Sensor"
        choice APP_ESPNOW_TEMP_MODE
            prompt "Temp Sensor ESP-NOW Mode"
            default APP_ESPNOW_TEMP_DISABLED
            help
                Master: Receive sensor data from slave (no local sensor needed).
                Slave:  Read local sensor and send data to master.
                Standalone: Sensor works locally, no ESP-NOW sync.
                Disabled: Hide from HomeKit, do not initialize.

            config APP_ESPNOW_TEMP_MASTER
                bool "Master"
            config APP_ESPNOW_TEMP_SLAVE
                bool "Slave"
            config APP_ESPNOW_TEMP_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_TEMP_DISABLED
                bool "Disabled"
        endchoice

        config APP_ESPNOW_TEMP_MAC
            string "Temp Sensor Slave MAC Address (If any targeted logic)"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_TEMP_MASTER
            help
                The MAC address of the slave device if you need to poll or send commands.
                (Currently Temp Slave broadcasts, so this might not be strictly used).

        config LAMP_SENSOR_AHT20
            bool "Enable AHT20 Sensor Hardware"
            default y
            depends on APP_ESPNOW_TEMP_SLAVE || APP_ESPNOW_TEMP_STANDALONE
            help
                Enable local AHT20 temperature & humidity sensor.
                Not needed when Temp is in Master mode (receives from slave).

        config APP_I2C_SDA
            int "I2C SDA GPIO"
            default 6
            depends on LAMP_SENSOR_AHT20
            help
                GPIO number for I2C SDA line.

        config APP_I2C_SCL
            int "I2C SCL GPIO"
            default 5
            depends on LAMP_SENSOR_AHT20
            help
                GPIO number for I2C SCL line.
    endmenu

    # --- LED Lamp 1 ---
    menu "LED Lamp 1"
        choice APP_ESPNOW_LED1_MODE
            prompt "LED 1 ESP-NOW Mode"
            default APP_ESPNOW_LED1_MASTER

            config APP_ESPNOW_LED1_MASTER
                bool "Master"
            config APP_ESPNOW_LED1_SLAVE
                bool "Slave"
            config APP_ESPNOW_LED1_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_LED1_DISABLED
                bool "Disabled"
        endchoice

        config APP_LED1_NAME
            string "LED 1 Custom Name"
            default "Lamp 1"
            depends on !APP_ESPNOW_LED1_DISABLED

        config APP_ESPNOW_LED1_MAC
            string "LED 1 Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_LED1_MASTER
            help
                The MAC address of the LED 1 slave device to send commands to.
                Format: XX:XX:XX:XX:XX:XX

        config APP_LED1_CONTROL
            bool "Enable LED 1 Hardware"
            default y
            depends on APP_ESPNOW_LED1_SLAVE || APP_ESPNOW_LED1_STANDALONE

        choice APP_LED1_TYPE
            prompt "LED 1 Type"
            default APP_LED1_TYPE_RGB_STRIP
            depends on APP_LED1_CONTROL

            config APP_LED1_TYPE_RGB_STRIP
                bool "RGB LED Strip (WS2812B/Addressable)"
            config APP_LED1_TYPE_SINGLE
                bool "Single LED (PWM/GPIO)"
        endchoice

        config APP_LED1_COUNT
            int "Number of LEDs (Lamp 1)"
            default 8
            depends on APP_LED1_CONTROL && APP_LED1_TYPE_RGB_STRIP

        config APP_LED1_GPIO
            int "LED 1 GPIO"
            default 2
            depends on APP_LED1_CONTROL
    endmenu

