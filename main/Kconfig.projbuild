        config APP_LED2_CONTROL
            bool "Enable LED 2 Hardware"
            default y
            depends on APP_ESPNOW_LED2_SLAVE || APP_ESPNOW_LED2_STANDALONE

        choice APP_LED2_TYPE
            prompt "LED 2 Type"
            default APP_LED2_TYPE_RGB_STRIP
            depends on APP_LED2_CONTROL

            config APP_LED2_TYPE_RGB_STRIP
                bool "RGB LED Strip (WS2812B/Addressable)"
            config APP_LED2_TYPE_SINGLE
                bool "Single LED (PWM/GPIO)"
        endchoice

        config APP_LED2_COUNT
            int "Number of LEDs (Lamp 2)"
            default 8
            depends on APP_LED2_CONTROL && APP_LED2_TYPE_RGB_STRIP

        config APP_LED2_GPIO
            int "LED 2 GPIO"
            default 8
            depends on APP_LED2_CONTROL
    endmenu

    # --- LED Lamp 3 ---
    menu "LED Lamp 3"
        choice APP_ESPNOW_LED3_MODE
            prompt "LED 3 ESP-NOW Mode"
            default APP_ESPNOW_LED3_DISABLED

            config APP_ESPNOW_LED3_MASTER
                bool "Master"
            config APP_ESPNOW_LED3_SLAVE
                bool "Slave"
            config APP_ESPNOW_LED3_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_LED3_DISABLED
                bool "Disabled"
        endchoice

        config APP_LED3_NAME
            string "LED 3 Custom Name"
            default "Lamp 3"
            depends on !APP_ESPNOW_LED3_DISABLED

        config APP_ESPNOW_LED3_MAC
            string "LED 3 Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_LED3_MASTER
            help
                The MAC address of the LED 3 slave device to send commands to.
                Format: XX:XX:XX:XX:XX:XX

        config APP_LED3_CONTROL
            bool "Enable LED 3 Hardware"
            default y
            depends on APP_ESPNOW_LED3_SLAVE || APP_ESPNOW_LED3_STANDALONE

        choice APP_LED3_TYPE
            prompt "LED 3 Type"
            default APP_LED3_TYPE_RGB_STRIP
            depends on APP_LED3_CONTROL

            config APP_LED3_TYPE_RGB_STRIP
                bool "RGB LED Strip (WS2812B/Addressable)"
            config APP_LED3_TYPE_SINGLE
                bool "Single LED (PWM/GPIO)"
        endchoice

        config APP_LED3_COUNT
            int "Number of LEDs (Lamp 3)"
            default 8
            depends on APP_LED3_CONTROL && APP_LED3_TYPE_RGB_STRIP

        config APP_LED3_GPIO
            int "LED 3 GPIO"
            default 9
            depends on APP_LED3_CONTROL
    endmenu

    # --- LED Lamp 4 ---
    menu "LED Lamp 4"
        choice APP_ESPNOW_LED4_MODE
            prompt "LED 4 ESP-NOW Mode"
            default APP_ESPNOW_LED4_DISABLED

            config APP_ESPNOW_LED4_MASTER
                bool "Master"
            config APP_ESPNOW_LED4_SLAVE
                bool "Slave"
            config APP_ESPNOW_LED4_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_LED4_DISABLED
                bool "Disabled"
        endchoice

        config APP_LED4_NAME
            string "LED 4 Custom Name"
            default "Lamp 4"
            depends on !APP_ESPNOW_LED4_DISABLED

        config APP_ESPNOW_LED4_MAC
            string "LED 4 Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_LED4_MASTER
            help
                The MAC address of the LED 4 slave device to send commands to.
                Format: XX:XX:XX:XX:XX:XX

        config APP_LED4_CONTROL
            bool "Enable LED 4 Hardware"
            default y
            depends on APP_ESPNOW_LED4_SLAVE || APP_ESPNOW_LED4_STANDALONE

        choice APP_LED4_TYPE
            prompt "LED 4 Type"
            default APP_LED4_TYPE_RGB_STRIP
            depends on APP_LED4_CONTROL

            config APP_LED4_TYPE_RGB_STRIP
                bool "RGB LED Strip (WS2812B/Addressable)"
            config APP_LED4_TYPE_SINGLE
                bool "Single LED (PWM/GPIO)"
        endchoice

        config APP_LED4_COUNT
            int "Number of LEDs (Lamp 4)"
            default 8
            depends on APP_LED4_CONTROL && APP_LED4_TYPE_RGB_STRIP

        config APP_LED4_GPIO
            int "LED 4 GPIO"
            default 10
            depends on APP_LED4_CONTROL
    endmenu

    # --- LED Lamp 5 ---
    menu "LED Lamp 5"
        choice APP_ESPNOW_LED5_MODE
            prompt "LED 5 ESP-NOW Mode"
            default APP_ESPNOW_LED5_DISABLED

            config APP_ESPNOW_LED5_MASTER
                bool "Master"
            config APP_ESPNOW_LED5_SLAVE
                bool "Slave"
            config APP_ESPNOW_LED5_STANDALONE
                bool "Standalone"
            config APP_ESPNOW_LED5_DISABLED
                bool "Disabled"
        endchoice

        config APP_LED5_NAME
            string "LED 5 Custom Name"
            default "Lamp 5"
            depends on !APP_ESPNOW_LED5_DISABLED

        config APP_ESPNOW_LED5_MAC
            string "LED 5 Slave MAC Address"
            default "FF:FF:FF:FF:FF:FF"
            depends on APP_ESPNOW_LED5_MASTER
            help
                The MAC address of the LED 5 slave device to send commands to.
                Format: XX:XX:XX:XX:XX:XX

        config APP_LED5_CONTROL
            bool "Enable LED 5 Hardware"
            default y
            depends on APP_ESPNOW_LED5_SLAVE || APP_ESPNOW_LED5_STANDALONE

        choice APP_LED5_TYPE
            prompt "LED 5 Type"
            default APP_LED5_TYPE_RGB_STRIP
            depends on APP_LED5_CONTROL

            config APP_LED5_TYPE_RGB_STRIP
                bool "RGB LED Strip (WS2812B/Addressable)"
            config APP_LED5_TYPE_SINGLE
                bool "Single LED (PWM/GPIO)"
        endchoice

        config APP_LED5_COUNT
            int "Number of LEDs (Lamp 5)"
            default 8
            depends on APP_LED5_CONTROL && APP_LED5_TYPE_RGB_STRIP

        config APP_LED5_GPIO
            int "LED 5 GPIO"
            default 18
            depends on APP_LED5_CONTROL
    endmenu


    menu "IR Hardware"
        depends on APP_ESPNOW_AC_SLAVE || APP_ESPNOW_AC_STANDALONE || APP_ESPNOW_FAN_SLAVE || APP_ESPNOW_FAN_STANDALONE
        comment "IR GPIOs needed when AC or Fan is Slave/Standalone"

        config APP_IR_TX_GPIO
            int "IR Transmitter GPIO"
            default 4

        config APP_IR_RX_GPIO
            int "IR Receiver GPIO"
            default 7
    endmenu

    config APP_BUTTON_GPIO
        int "Button GPIO"
        default 3

    config APP_BUTTON_ACTIVE_LEVEL
        int "Button Active Level"
        default 0
        range 0 1

endmenu

# =============================================================================
# ESP-NOW Auto-Computed Flags & Peer Config
# =============================================================================
menu "ESP-NOW Configuration"

    config APP_ESPNOW_BRIDGE_ENABLE
        bool
        default y if APP_ESPNOW_AC_MASTER || APP_ESPNOW_FAN_MASTER || APP_ESPNOW_TEMP_SLAVE || APP_ESPNOW_LED1_MASTER || APP_ESPNOW_LED2_MASTER || APP_ESPNOW_LED3_MASTER || APP_ESPNOW_LED4_MASTER || APP_ESPNOW_LED5_MASTER

    config APP_ESPNOW_SLAVE_ENABLE
        bool
        default y if APP_ESPNOW_AC_SLAVE || APP_ESPNOW_FAN_SLAVE || APP_ESPNOW_TEMP_MASTER || APP_ESPNOW_LED1_SLAVE || APP_ESPNOW_LED2_SLAVE || APP_ESPNOW_LED3_SLAVE || APP_ESPNOW_LED4_SLAVE || APP_ESPNOW_LED5_SLAVE

    config APP_ESPNOW_PEER_MAC
        string "Peer device MAC Address"
        default "FF:FF:FF:FF:FF:FF"
        depends on APP_ESPNOW_BRIDGE_ENABLE || APP_ESPNOW_SLAVE_ENABLE

endmenu

# =============================================================================
# Mobile Platform
# =============================================================================
menu "Mobile Platform"

    choice LAMP_MOBILE_PLATFORM
        prompt "Platform Selection"
        default LAMP_PLATFORM_IOS

        config LAMP_PLATFORM_ANDROID
            bool "Android (ESP RainMaker)"
            select ESP_RAINMAKER_ENABLE

        config LAMP_PLATFORM_IOS
            bool "iOS (Apple HomeKit)"
    endchoice

endmenu

# =============================================================================
# WiFi Configuration
# =============================================================================
menu "WiFi Configuration"

    choice APP_PROV_TRANSPORT_METHOD
        prompt "Provisioning Transport Method"
        default APP_WIFI_PROV_TRANSPORT_SOFTAP

        config APP_WIFI_PROV_TRANSPORT_SOFTAP
            bool "SoftAP"
        config APP_WIFI_PROV_TRANSPORT_BLE
            bool "BLE"
    endchoice

    config APP_PROV_SERVICE_NAME
        string "Provisioning Service Name"
        default "PROV_LAMP_IR"

    config APP_PROV_POP
        string "Proof of Possession (PoP)"
        default "12345678"

    config APP_WIFI_FALLBACK_SSID
        string "Fallback AP SSID"
        default "Lamp-Recovery"

    config APP_WIFI_FALLBACK_PASSWORD
        string "Fallback AP Password"
        default "12345678"

endmenu

# =============================================================================
# OTA Configuration
# =============================================================================
menu "OTA Configuration"

    config OTA_SERVER_URL
        string "OTA Server URL"
        default "https://salty-mouth.surge.sh"

    config OTA_CHECK_INTERVAL
        int "OTA Check Interval (seconds)"
        default 3600

endmenu

# =============================================================================
# iOS WiFi Provisioning
# =============================================================================
menu "iOS WiFi Provisioning"
    depends on LAMP_PLATFORM_IOS

    config IOS_WIFI_PROV_AP_ENABLE
        bool "Enable SoftAP WiFi Provisioning for iOS"
        default y

    config IOS_WIFI_AP_SSID_PREFIX
        string "SoftAP SSID Prefix"
        default "Lamp-Setup"
        depends on IOS_WIFI_PROV_AP_ENABLE

    config IOS_WIFI_AP_PASSWORD
        string "SoftAP Password (leave empty for open)"
        default ""
        depends on IOS_WIFI_PROV_AP_ENABLE

    config IOS_WIFI_AP_CHANNEL
        int "SoftAP WiFi Channel"
        default 1
        range 1 13
        depends on IOS_WIFI_PROV_AP_ENABLE

    config IOS_WIFI_AP_MAX_CONNECTIONS
        int "Maximum SoftAP Connections"
        default 4
        range 1 10
        depends on IOS_WIFI_PROV_AP_ENABLE

endmenu
