# PSRAM Configuration for ESP32-S3 (Disabled due to hardware mismatch)
CONFIG_SPIRAM=n

# Device Role Configuration
CONFIG_APP_ESPNOW_AC_MASTER=y
CONFIG_APP_ESPNOW_AC_MAC="48:ca:43:cf:ff:68"

CONFIG_APP_ESPNOW_FAN_MASTER=y
CONFIG_APP_ESPNOW_FAN_MAC="48:ca:43:cf:ff:68"

CONFIG_APP_ESPNOW_TEMP_MASTER=y
CONFIG_APP_ESPNOW_TEMP_MAC="48:ca:43:cf:ff:68"

CONFIG_APP_ESPNOW_LED1_MASTER=y
CONFIG_APP_ESPNOW_LED1_MAC="e4:65:b8:11:7f:9c"

CONFIG_APP_ESPNOW_RELAY_MASTER=y
CONFIG_APP_ESPNOW_RELAY_MAC="48:ca:43:cb:08:b0"

# LCD Configuration
CONFIG_APP_LCD_ENABLE=y
CONFIG_APP_LCD_BACKLIGHT_GPIO=6
CONFIG_APP_LCD_CS_GPIO=5
CONFIG_APP_LCD_DC_GPIO=4
CONFIG_APP_LCD_RST_GPIO=3
CONFIG_APP_LCD_MOSI_GPIO=2
CONFIG_APP_LCD_SCLK_GPIO=1
CONFIG_APP_LCD_H_RES=240
CONFIG_APP_LCD_V_RES=240
CONFIG_APP_LCD_SPI_HOST=0

# Sensor Configuration
CONFIG_APP_ESPNOW_TEMP_SLAVE=y
CONFIG_LAMP_SENSOR_AHT20=y
CONFIG_APP_I2C_SDA=7
CONFIG_APP_I2C_SCL=8

# Button Configuration
CONFIG_APP_BUTTON_GPIO=0
CONFIG_APP_BUTTON_ACTIVE_LEVEL=0

# Sync Peers Configuration
CONFIG_APP_ESPNOW_SYNC_PEER_1="48:ca:43:cf:ff:68"
CONFIG_APP_ESPNOW_SYNC_PEER_2="e4:65:b8:11:7f:9c"
CONFIG_APP_ESPNOW_SYNC_PEER_3="48:ca:43:cb:08:b0"

# LVGL Font Configuration
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_48=y

# Flash Size Configuration
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
# LVGL Sharpness Fix
CONFIG_LV_COLOR_16_SWAP=y
